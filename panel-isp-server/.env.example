NODE_ENV_CONFIG=development
PORT=3000

DEV_DB_URL=mongodb://localhost:27017
DEV_DB_NAME=panel_isp_dev

TEST_DB_URL=mongodb://localhost:27017
TEST_DB_NAME=panel_isp_test

PROD_DB_URL=mongodb://localhost:27017
PROD_DB_NAME=panel_isp_prod

MIKROTIK_HOST=192.168.1.1
MIKROTIK_REST_SCHEME=http
MIKROTIK_REST_PORT=80
MIKROTIK_REST_TLS_INSECURE=true
MIKROTIK_USER=panel-api
MIKROTIK_PASS=gantipassword

MIKROTIK_PELANGGAN_INTERFACE=ether4

IP_POOL_NETWORK=10.10.0.0
IP_POOL_START=10
IP_POOL_END=254

# Wajib: minimal 16 karakter. Server menolak start bila kosong/terlalu pendek.
JWT_SECRET=ganti-dengan-string-acak-panjang-minimal-16
JWT_EXPIRES_IN=7d

# Akun admin awal (dipakai oleh scripts/seed.ts). Ganti password default!
ADMIN_USERNAME=admin
ADMIN_PASS=gantipassword

# CORS: kosong/'*' = izinkan semua (cocok untuk Bearer token). Untuk membatasi,
# isi origin web, pisahkan dengan koma. Contoh: http://localhost:3001
CORS_ORIGIN=

# Timezone untuk cron auto-suspend & reminder (default Asia/Jakarta = WIB).
CRON_TZ=Asia/Jakarta

DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/id/token
